#!/bin/sh
set -e

# Ensure the script runs from the repository root
cd "$(git rev-parse --show-toplevel)"

echo "Checking for typos..."
typos

echo "Fixing all markdown files..."

find . -type d \( -name target -o -name .git \) -prune -o \
  -type f -name "*.md" \
  ! -name "CHANGELOG.md" \
  ! -name "plan.md" \
  -exec rumdl check --fix {} +

find . -type d \( -name target -o -name .git \) -prune -o \
  -type f -name "*.md" \
  ! -name "CHANGELOG.md" \
  ! -name "plan.md" \
  -exec git add {} +

exit 0
